# Atlas (SRV): add tlsDisableOCSPEndpointCheck=true if you see TLS handshake / internal alert errors on Python 3.13+ (still verifies the server cert).
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&tlsDisableOCSPEndpointCheck=true
# Local: mongodb://localhost:27017
DATABASE_NAME=taskmanager
JWT_SECRET=team-task-secret
JWT_EXPIRE_MINUTES=1440
